{
  "contract": "project-root.golden",
  "cases": [
    {
      "name": "env-override-wins",
      "note": "FABRIC_PROJECT_ROOT beats every other signal (S15).",
      "signals": {
        "env": "/home/u/work/projA",
        "markerDir": "/home/u/work/projA",
        "cwd": "/home/u/work/projA/src/auth",
        "repoRoot": "/home/u/work/projA",
        "discoveredProjectId": "11111111-1111-4111-8111-111111111111"
      },
      "expected": {
        "projectRoot": "/home/u/work/projA",
        "projectId": "11111111-1111-4111-8111-111111111111",
        "signalUsed": "env"
      }
    },
    {
      "name": "ancestor-marker-wins-no-env",
      "note": "Nearest ancestor with .fabric/fabric-config.json; markerDir != cwd → 'marker' (S32: one repo = one .fabric = one project_id).",
      "signals": {
        "markerDir": "/home/u/work/projA",
        "cwd": "/home/u/work/projA/src/auth",
        "repoRoot": "/home/u/work/projA",
        "discoveredProjectId": "11111111-1111-4111-8111-111111111111"
      },
      "expected": {
        "projectRoot": "/home/u/work/projA",
        "projectId": "11111111-1111-4111-8111-111111111111",
        "signalUsed": "marker"
      }
    },
    {
      "name": "cwd-is-marker-no-ancestor",
      "note": "cwd itself carries the .fabric marker (markerDir === cwd) → 'cwd'; wins over bare repo root.",
      "signals": {
        "markerDir": "/home/u/work/projB",
        "cwd": "/home/u/work/projB",
        "repoRoot": "/home/u/work",
        "discoveredProjectId": "22222222-2222-4222-8222-222222222222"
      },
      "expected": {
        "projectRoot": "/home/u/work/projB",
        "projectId": "22222222-2222-4222-8222-222222222222",
        "signalUsed": "cwd"
      }
    },
    {
      "name": "repo-root-fallback-no-marker",
      "note": "git repo, no .fabric marker anywhere; repoRoot wins. discoveredProjectId present = repo previously installed.",
      "signals": {
        "cwd": "/home/u/work/projC/pkg/server",
        "repoRoot": "/home/u/work/projC",
        "discoveredProjectId": "33333333-3333-4333-8333-333333333333"
      },
      "expected": {
        "projectRoot": "/home/u/work/projC",
        "projectId": "33333333-3333-4333-8333-333333333333",
        "signalUsed": "repo"
      }
    },
    {
      "name": "no-signal-yields-null",
      "note": "Not inside any project and not a repo, no marker, no env → resolver returns null.",
      "signals": {
        "cwd": "/tmp/scratch"
      },
      "expected": null
    },
    {
      "name": "worktree-merges-by-project-id",
      "note": "S45: a git worktree of projA has a different path but its .fabric carries projA's project_id, so it resolves to the SAME project_id.",
      "signals": {
        "markerDir": "/home/u/work/projA-wt-feature",
        "cwd": "/home/u/work/projA-wt-feature/src",
        "repoRoot": "/home/u/work/projA-wt-feature",
        "discoveredProjectId": "11111111-1111-4111-8111-111111111111"
      },
      "expected": {
        "projectRoot": "/home/u/work/projA-wt-feature",
        "projectId": "11111111-1111-4111-8111-111111111111",
        "signalUsed": "marker"
      }
    }
  ]
}
