{
  "name": "@fenglimg/fabric-shared",
  "version": "2.3.0-rc.10",
  "description": "Fabric shared types — Zod schemas, i18n, atomic-write helpers, MCP payload guard, error classes. Consumed by @fenglimg/fabric-server + @fenglimg/fabric-cli.",
  "license": "MIT",
  "author": "wangzhichao <fenglimg90@gmail.com>",
  "homepage": "https://github.com/fenglimg/fabric-v2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fenglimg/fabric-v2.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/fenglimg/fabric-v2/issues"
  },
  "keywords": [
    "fabric",
    "shared",
    "zod-schemas",
    "i18n",
    "mcp"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./i18n": {
      "development": "./src/i18n/index.ts",
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./types": {
      "development": "./src/types/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./node": {
      "development": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./node/atomic-write": {
      "development": "./src/node/atomic-write.ts",
      "types": "./dist/node/atomic-write.d.ts",
      "import": "./dist/node/atomic-write.js"
    },
    "./node/mcp-payload-guard": {
      "development": "./src/node/mcp-payload-guard.ts",
      "types": "./dist/node/mcp-payload-guard.d.ts",
      "import": "./dist/node/mcp-payload-guard.js"
    },
    "./errors": {
      "development": "./src/errors/index.ts",
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js"
    },
    "./schemas/api-contracts": {
      "development": "./src/schemas/api-contracts.ts",
      "types": "./dist/schemas/api-contracts.d.ts",
      "import": "./dist/schemas/api-contracts.js"
    },
    "./templates/bootstrap-canonical": {
      "development": "./src/templates/bootstrap-canonical.ts",
      "types": "./dist/templates/bootstrap-canonical.d.ts",
      "import": "./dist/templates/bootstrap-canonical.js"
    },
    "./theme": {
      "development": "./src/theme.ts",
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/i18n/index.ts src/types/index.ts src/node.ts src/node/atomic-write.ts src/node/mcp-payload-guard.ts src/errors/index.ts src/schemas/api-contracts.ts src/templates/bootstrap-canonical.ts src/theme.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/i18n/index.ts src/types/index.ts src/node.ts src/node/atomic-write.ts src/node/mcp-payload-guard.ts src/errors/index.ts src/schemas/api-contracts.ts src/templates/bootstrap-canonical.ts src/theme.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run --config vitest.smoke.config.ts"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.3.0",
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
