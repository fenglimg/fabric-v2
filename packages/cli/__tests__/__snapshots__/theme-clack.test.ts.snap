// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`theme-clack context wrap (NO_COLOR) > buildIntro renders a B-横线 header (title + rule) 1`] = `
"Fabric install
----------------------------------------"
`;

exports[`theme-clack context wrap (NO_COLOR) > buildLog renders all four levels 1`] = `
{
  "error": "[error] error message",
  "info": "info message",
  "success": "[ok] success message",
  "warn": "[warn] warn message",
}
`;

exports[`theme-clack context wrap (NO_COLOR) > buildNote renders a gutter-free indented block with optional title 1`] = `
{
  "titled": "Overview
----------------------------------------
  line one
  line two",
  "untitled": "  solo line",
}
`;

exports[`theme-clack context wrap (NO_COLOR) > buildOutro renders a closing line 1`] = `"Done"`;

exports[`theme-clack context wrap (NO_COLOR) > buildPromptReceipt renders a gutter-free ✓ line for set/selected and an x line for cancelled 1`] = `
{
  "cancelled": "[error] Cancelled",
  "selected": "[ok] Selected · bootstrap templates, MCP clients",
  "set": "[ok] Set · zh-CN",
  "setNoValue": "[ok] Set",
}
`;
