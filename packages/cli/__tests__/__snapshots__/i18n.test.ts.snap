      "Created <fixture-2>/.fabric/knowledge",
      "Created <fixture-2>/.fabric/agents.meta.json",
      "Created <fixture-2>/.fabric/events.jsonl",
      "Created <fixture-2>/.fabric/forensic.json",
      "Next Installing bootstrap templates...",
      "completed bootstrap: installed=13 skipped=2",
      "Next Configuring MCP clients...",
      "Next Installing git hooks...",
      "completed hooks: installed=0 skipped=15",
      "Reason .fabric/forensic.json is ready; some detected clients support Fabric follow-up but still need client assets installed.",
      "ran: bootstrap, hooks",
      "skipped: none",
      "failed: mcp",
      "Client capability summary",
      "Client           Bootstrap  MCP     Hook       Skill      Follow-up         ",
      "---------------  ---------  ------  ---------  ---------  ------------------",
      "Claude Code CLI  ready      failed  installed  installed  continue in client",
    ],
  },
  "locale": "en",
  "scan": {
    "description": "Scan the project to detect Fabric bootstrap candidates.",
    "errors": [
      "[warn] forensic.json not found at <fixture-3>/.fabric/forensic.json; run \`fabric init\` first to produce the deterministic project snapshot.",
    ],
    "stderr": [],
    "stdout": [],
  },
  "serve": {
    "description": "Start the local Fabric MCP HTTP service. Set FABRIC_AUTH_TOKEN to enable Bearer auth for non-localhost binding.",
    "errors": [
      "[warn] --host 0.0.0.0 requires FABRIC_AUTH_TOKEN; falling back to 127.0.0.1 for safety",
    ],
    "stderr": [],
    "stdout": [
      "[ok] Fabric Dashboard http://127.0.0.1:7373",
    ],
  },
}
`;

