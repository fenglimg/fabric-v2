// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`cli i18n > renders en command descriptions and output snapshots 1`] = `
{
  "init": {
    "description": "Initialize Fabric in the target project.",
    "errors": [],
    "stderr": [
      "Using globally-installed @fenglimg/fabric-server",
      "failed mcp: __vite_ssr_import_meta__.resolve is not a function",
      "failed hooks: fab hooks install is not available in v2 (husky pre-commit template removed). Use per-client hooks under .claude/ and .codex/ instead. Target: <fixture-2>",
    ],
    "stdout": [
      "Created <fixture-2>/AGENTS.md",
      "Created <fixture-2>/.fabric/knowledge",
      "Created <fixture-2>/.fabric/agents.meta.json",
      "Created <fixture-2>/.fabric/events.jsonl",
      "Created <fixture-2>/.fabric/forensic.json",
      "Next Installing bootstrap templates...",
      "skipped bootstrap: installed=0 skipped=0 (No bootstrap targets detected. Pass --clients claude,cursor,codex to install explicitly.)",
      "Next Configuring MCP clients...",
      "Next Installing git hooks...",
      "Next run fab hooks install to add the Day 4 pre-commit pipeline.",
      "Reason .fabric/forensic.json is ready; some detected clients still need manual follow-up because no Fabric skill is installed for them yet.",
      "ran: none",
      "skipped: bootstrap",
      "failed: mcp, hooks",
      "No supported client was detected for bootstrap or MCP follow-up.",
    ],
  },
  "locale": "en",
  "scan": {
    "description": "Scan the project to detect Fabric bootstrap candidates.",
    "errors": [
      "[warn] forensic.json not found at <fixture-3>/.fabric/forensic.json; run \`fabric init\` first to produce the deterministic project snapshot.",
    ],
    "stderr": [],
    "stdout": [],
  },
  "serve": {
    "description": "Start the local Fabric MCP HTTP service. Set FABRIC_AUTH_TOKEN to enable Bearer auth for non-localhost binding.",
    "errors": [
      "[warn] --host 0.0.0.0 requires FABRIC_AUTH_TOKEN; falling back to 127.0.0.1 for safety",
    ],
    "stderr": [],
    "stdout": [
      "[ok] Fabric Dashboard http://127.0.0.1:7373",
    ],
  },
}
`;

