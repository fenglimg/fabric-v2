// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`cli i18n > renders en command descriptions and output snapshots 1`] = `
{
  "config": {
    "description": "Open the interactive Fabric configuration panel (language, knowledge layer, audit mode, hint windows, MCP client wiring, etc.).

Examples:
  fabric config                   open the interactive panel
  fabric config --target /path    edit configuration for a specific project",
    "errors": [
      "Workspace not initialized. Run \`fabric install\` first.",
    ],
    "stderr": [],
    "stdout": [],
  },
  "install": {
    "description": "Install Fabric in the target project (scaffold .fabric/, bootstrap templates, MCP client wiring, git hooks).

Examples:
  fabric install                  interactive install in the current project
  fabric install --yes            accept defaults, skip the TTY wizard
  fabric install --dry-run        preview the install plan without writing files",
    "errors": [],
    "stderr": [
      "Using globally-installed @fenglimg/fabric-server",
      "failed mcp: __vite_ssr_import_meta__.resolve is not a function",
    ],
    "stdout": [
      "Created <fixture-2>\\AGENTS.md",
      "Created <fixture-2>\\.fabric\\events.jsonl",
      "Created <fixture-2>\\.fabric\\forensic.json",
      "Next Installing bootstrap templates...",
      "completed bootstrap: installed=129 skipped=2",
      "Next Configuring MCP clients...",
      "Next Installing git hooks...",
      "completed hooks: installed=2 skipped=142",
      "Reason .fabric/forensic.json is ready; some detected clients support Fabric follow-up but still need client assets installed.",
      "ran: bootstrap, hooks",
      "skipped: none",
      "failed: mcp",
      "Client capability summary",
      "Client               Bootstrap  MCP     Hook       Skill      Follow-up          ",
      "-------------------  ---------  ------  ---------  ---------  -------------------",
      "Claude Code CLI      ready      failed  installed  installed  ready after restart",
      "Claude Code Desktop  ready      failed  installed  installed  ready after restart",
      "Cursor               ready      failed  installed  installed  ready after restart",
      "Codex CLI            ready      failed  installed  installed  ready after restart",
      "Codex Desktop        ready      failed  installed  installed  ready after restart",
      "",
      "Restart hint: any already-running Claude Code / Cursor / Codex session must restart to pick up the new MCP / Hook / Bootstrap config; new sessions will use the Fabric tools.",
      "Fabric language preference: en. To change, edit \`fabric_language\` in \`.fabric/fabric-config.json\` (values: match-existing | zh-CN | en | zh-CN-hybrid).",
      "",
      "Next steps — verify Fabric is connected:
  1. Restart any running AI client; new sessions load the latest MCP / Hook / Bootstrap config.
  2. Confirm the write target: new knowledge writes to the active write store and starts in knowledge/pending/.
  3. Capture knowledge as you work; use fabric-archive for decisions or pitfalls, and fabric-import for history backfill.
  4. Promote knowledge with fabric-review; pending entries become canonical only after review.
  5. Verify state with \`fabric doctor\`, or ask a restarted client "what does Fabric know about this repo?".",
      "",
      "More: docs/ARCHITECTURE.md explains CLI / Skill / MCP boundaries.",
      "",
      "💡 Mounted store(s) not bound to this project: 'team'. Run \`fabric store bind team\` to read their knowledge here, then \`fabric store switch-write team\` to write team knowledge into it.",
    ],
  },
  "locale": "en",
  "uninstall": {
    "description": "Uninstall Fabric from the target project. Global knowledge stores under ~/.fabric/stores/ are never deleted by project uninstall.

Examples:
  fabric uninstall                interactive uninstall in the current project
  fabric uninstall --yes          accept defaults, skip the TTY wizard
  fabric uninstall --dry-run      preview the uninstall plan without removing files",
    "usage": "fabric uninstall - Uninstall Fabric from the target project. Global knowledge stores under ~/.fabric/stores/ are never deleted by project uninstall.

Examples:
  fabric uninstall                interactive uninstall in the current project
  fabric uninstall --yes          accept defaults, skip the TTY wizard
  fabric uninstall --dry-run      preview the uninstall plan without removing files",
  },
}
`;

exports[`cli i18n > renders zh-CN command descriptions and output snapshots 1`] = `
{
  "config": {
    "description": "打开 Fabric 交互式配置面板（语言、知识层、审计模式、提示窗口、MCP 客户端配置等）。

示例：
  fabric config                   打开交互式面板
  fabric config --target /path    编辑指定项目的配置",
    "errors": [
      "工作区尚未初始化。请先运行 \`fabric install\`。",
    ],
    "stderr": [],
    "stdout": [],
  },
  "install": {
    "description": "在目标项目中安装 Fabric（脚手架 .fabric/、bootstrap 模板、MCP 客户端配置、git hooks）。

示例：
  fabric install                  在当前项目中以交互模式安装
  fabric install --yes            接受默认值，跳过 TTY 向导
  fabric install --dry-run        仅预览安装计划，不写入文件",
    "errors": [],
    "stderr": [
      "使用全局安装的 @fenglimg/fabric-server",
      "失败 mcp: __vite_ssr_import_meta__.resolve is not a function",
    ],
    "stdout": [
      "已创建 <fixture-2>\\AGENTS.md",
      "已创建 <fixture-2>\\.fabric\\events.jsonl",
      "已创建 <fixture-2>\\.fabric\\forensic.json",
      "下一步 正在安装 bootstrap 模板...",
      "已完成 bootstrap: installed=129 skipped=2",
      "下一步 正在配置 MCP 客户端...",
      "下一步 正在安装 git hooks...",
      "已完成 hooks: installed=2 skipped=142",
      "原因 .fabric/forensic.json 已就绪；部分已检测到的客户端已支持 Fabric 后续接力，但仍需安装客户端资产。",
      "已执行: bootstrap, hooks",
      "已跳过: 无",
      "失败: mcp",
      "客户端能力摘要",
      "客户端               Bootstrap  MCP   Hook    Skill   后续动作  ",
      "-------------------  ---------  ----  ------  ------  ----------",
      "Claude Code CLI      已就绪     失败  已安装  已安装  重启后可用",
      "Claude Code Desktop  已就绪     失败  已安装  已安装  重启后可用",
      "Cursor               已就绪     失败  已安装  已安装  重启后可用",
      "Codex CLI            已就绪     失败  已安装  已安装  重启后可用",
      "Codex Desktop        已就绪     失败  已安装  已安装  重启后可用",
      "",
      "重启提示：已运行的 Claude Code / Cursor / Codex session 需重启才能加载新的 MCP / Hook / Bootstrap 配置；新会话会使用 Fabric tools。",
      "Fabric 语言偏好：en。如需调整，请编辑 .fabric/fabric-config.json 中的 fabric_language 字段（可选值：match-existing | zh-CN | en | zh-CN-hybrid）。",
      "",
      "下一步 —— 验证 Fabric 已接入：
  1. 重启正在运行的 AI 客户端；新会话才会加载最新 MCP / Hook / Bootstrap 配置。
  2. 确认知识写入目标：新知识会写入 active write store，并先进入 knowledge/pending/。
  3. 开始沉淀知识：正常工作即可；有决策、踩坑或历史回灌需求时，使用 fabric-archive / fabric-import。
  4. 审核入库：用 fabric-review 审核 pending 条目后，知识才会进入正式知识库。
  5. 验证状态：运行 \`fabric doctor\`，或在重启后的客户端询问「Fabric 对这个 repo 知道些什么？」。",
      "",
      "More: docs/ARCHITECTURE.md explains CLI / Skill / MCP boundaries.",
      "",
      "💡 检测到已挂载但未绑定本项目的知识 store: 'team'。运行 \`fabric store bind team\` 把它的知识接入本项目, 再 \`fabric store switch-write team\` 设为团队知识的写入目标。",
    ],
  },
  "locale": "zh-CN",
  "uninstall": {
    "description": "从目标项目中卸载 Fabric。项目卸载永远不会删除 ~/.fabric/stores/ 下的全局知识 store。

示例：
  fabric uninstall                在当前项目中以交互模式卸载
  fabric uninstall --yes          接受默认值，跳过 TTY 向导
  fabric uninstall --dry-run      仅预览卸载计划，不删除文件",
    "usage": "fabric uninstall - 从目标项目中卸载 Fabric。项目卸载永远不会删除 ~/.fabric/stores/ 下的全局知识 store。

示例：
  fabric uninstall                在当前项目中以交互模式卸载
  fabric uninstall --yes          接受默认值，跳过 TTY 向导
  fabric uninstall --dry-run      仅预览卸载计划，不删除文件",
  },
}
`;
