      "description": "Listen host, default 127.0.0.1. Non-loopback hosts (e.g. 0.0.0.0) require FABRIC_AUTH_TOKEN to enable Bearer auth, otherwise serve falls back to 127.0.0.1.",
      "name": "host",
      "negativeDescription": undefined,
      "required": undefined,
      "type": "string",
    },
    {
      "alias": undefined,
