exports[`tool contracts > knowledge-sections contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Filter rule sections",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "ai_selected_stable_ids": {
        "description": "Stable ids picked from fab_plan_context entries[].description_index[].stable_id where selectable=true; choose 1..N to fetch bodies for",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "ai_selection_reasons": {
        "additionalProperties": {
          "minLength": 1,
          "type": "string",
        },
        "description": "Reason for each AI-selected L1 stable_id",
        "type": "object",
      },
      "client_hash": {
        "description": "Optional caller-provided client hash propagated into knowledge_consumed events",
        "type": "string",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records",
        "type": "string",
      },
      "selection_token": {
        "description": "Selection token returned by fab_plan_context",
        "minLength": 1,
        "type": "string",
      },
      "session_id": {
        "description": "Optional caller-provided session id for Event Ledger records",
        "type": "string",
      },
    },
    "required": [
      "selection_token",
      "ai_selected_stable_ids",
      "ai_selection_reasons",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "diagnostics": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "code": {
              "const": "missing_knowledge_metadata",
              "type": "string",
            },
            "message": {
              "type": "string",
            },
            "severity": {
              "const": "warn",
              "type": "string",
            },
            "stable_id": {
              "type": "string",
            },
          },
          "required": [
            "code",
            "severity",
            "stable_id",
            "message",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "precedence": {
        "description": "DEPRECATED (removed in rc.24): hardcoded L2/L1/L0 precedence tuple from the retired rc.5 selection ceremony. Use rules[].level instead.",
        "items": [
          {
            "const": "L2",
            "type": "string",
          },
          {
            "const": "L1",
            "type": "string",
          },
          {
            "const": "L0",
            "type": "string",
          },
        ],
        "maxItems": 3,
        "minItems": 3,
        "type": "array",
      },
      "redirect_to": {
        "additionalProperties": false,
        "description": "Post-layer-flip redirect. Populated when stable_id changed after token mint (rc.3 fab_review/modify).",
        "properties": {
          "stable_id": {
            "type": "string",
          },
        },
        "required": [
          "stable_id",
        ],
        "type": "object",
      },
      "revision_hash": {
        "type": "string",
      },
      "rules": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "body": {
              "type": "string",
            },
            "level": {
              "enum": [
                "L0",
                "L1",
                "L2",
              ],
              "type": "string",
            },
            "path": {
              "type": "string",
            },
            "stable_id": {
              "type": "string",
            },
          },
          "required": [
            "stable_id",
            "level",
            "path",
            "body",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "selected_stable_ids": {
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
          },
          "required": [
            "code",
            "file",
            "action_hint",
          ],
          "type": "object",
        },
        "type": "array",
      },
    },
    "required": [
      "revision_hash",
      "selected_stable_ids",
      "rules",
      "diagnostics",
    ],
    "type": "object",
  },
}
`;

exports[`tool contracts > plan-context contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Plan rule context",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "client_hash": {
        "description": "Revision hash from a prior fab_plan_context response; enables stale detection",
        "type": "string",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records",
        "type": "string",
      },
      "detected_entities": {
        "additionalProperties": {
          "items": {
            "type": "string",
          },
          "type": "array",
        },
        "description": "Optional path-keyed detected entities for the requirement profile",
        "type": "object",
      },
      "intent": {
        "description": "User-stated requirement or implementation intent; used only to build a neutral requirement profile",
        "type": "string",
      },
      "known_tech": {
        "description": "Known technologies involved in the requirement profile",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "layer_filter": {
        "description": "Restrict description_index to the named layer. Default: fabric-config.default_layer_filter (TASK-002).",
        "enum": [
          "team",
          "personal",
          "both",
        ],
        "type": "string",
      },
      "paths": {
        "description": "Candidate file paths to build neutral rule selection context for",
        "items": {
          "type": "string",
        },
        "minItems": 1,
        "type": "array",
      },
      "session_id": {
        "description": "Optional caller-provided session id for Event Ledger records",
        "type": "string",
      },
      "target_paths": {
        "description": "Path context for narrow-scope relevance filtering. Defaults to \`paths\`; empty = no filter.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
    },
    "required": [
      "paths",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "auto_healed": {
        "type": "boolean",
      },
      "entries": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "description_index": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "description": {
                    "additionalProperties": false,
                    "properties": {
                      "created_at": {
                        "type": "string",
                      },
                      "entities": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "id": {
                        "type": "string",
                      },
                      "impact": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "intent_clues": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "knowledge_layer": {
                        "enum": [
                          "personal",
                          "team",
                        ],
                        "type": "string",
                      },
                      "knowledge_type": {
                        "enum": [
                          "model",
                          "decision",
                          "guideline",
                          "pitfall",
                          "process",
                        ],
                        "type": "string",
                      },
                      "layer_reason": {
                        "type": "string",
                      },
                      "maturity": {
                        "enum": [
                          "draft",
                          "verified",
                          "proven",
                        ],
                        "type": "string",
                      },
                      "must_read_if": {
                        "type": "string",
                      },
                      "summary": {
