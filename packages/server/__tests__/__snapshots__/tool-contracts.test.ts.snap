exports[`tool contracts > plan-context contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Plan rule context",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "client_hash": {
        "description": "Revision hash from a prior fab_plan_context response; enables stale detection",
        "type": "string",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records",
        "type": "string",
      },
      "detected_entities": {
        "additionalProperties": {
          "items": {
            "type": "string",
          },
          "type": "array",
        },
        "description": "Optional path-keyed detected entities for the requirement profile",
        "type": "object",
      },
      "intent": {
        "description": "User-stated requirement or implementation intent; used only to build a neutral requirement profile",
        "type": "string",
      },
      "known_tech": {
        "description": "Known technologies involved in the requirement profile",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "layer_filter": {
        "description": "Restrict description_index to the named layer. Default: fabric-config.default_layer_filter (TASK-002).",
        "enum": [
          "team",
          "personal",
          "both",
        ],
        "type": "string",
      },
      "paths": {
        "description": "Candidate file paths to build neutral rule selection context for",
        "items": {
          "type": "string",
        },
        "minItems": 1,
        "type": "array",
      },
      "session_id": {
        "description": "Recommended: pass the current client session id (Claude Code: $session_id; Codex: corresponding identifier) — enables cross-session debt tracking in fabric doctor and accurate archive-hint cross-session count. Falls back gracefully if omitted.",
        "type": "string",
      },
      "target_paths": {
        "description": "Path context for narrow-scope relevance filtering. Defaults to \`paths\`; empty = no filter.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
    },
    "required": [
      "paths",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "auto_healed": {
        "type": "boolean",
      },
      "candidates": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "always_active": {
              "type": "boolean",
            },
            "description": {
              "additionalProperties": false,
              "properties": {
                "created_at": {
                  "type": "string",
                },
                "entities": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "id": {
                  "type": "string",
                },
                "impact": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "intent_clues": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "knowledge_layer": {
                  "enum": [
                    "personal",
                    "team",
                  ],
                  "type": "string",
                },
                "knowledge_type": {
                  "enum": [
                    "models",
                    "decisions",
                    "guidelines",
                    "pitfalls",
                    "processes",
                  ],
                  "type": "string",
                },
                "layer_reason": {
                  "type": "string",
                },
                "maturity": {
                  "enum": [
                    "draft",
                    "verified",
                    "proven",
                  ],
                  "type": "string",
                },
                "must_read_if": {
                  "type": "string",
                },
                "related": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "relevance_paths": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "relevance_scope": {
                  "enum": [
                    "narrow",
                    "broad",
                  ],
                  "type": "string",
                },
                "summary": {
                  "type": "string",
                },
                "tags": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "tech_stack": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
              },
              "required": [
                "summary",
                "intent_clues",
                "tech_stack",
                "impact",
                "must_read_if",
              ],
              "type": "object",
            },
            "stable_id": {
              "type": "string",
            },
          },
          "required": [
            "stable_id",
            "description",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "entries": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
            },
            "requirement_profile": {
              "additionalProperties": false,
              "properties": {
                "detected_entities": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "known_tech": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "target_path": {
                  "type": "string",
                },
              },
              "required": [
