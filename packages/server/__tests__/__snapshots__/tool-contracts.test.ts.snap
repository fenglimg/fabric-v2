                      "created_at": {
                        "type": "string",
                      },
                      "entities": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "id": {
                        "type": "string",
                      },
                      "impact": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "intent_clues": {
                        "items": {
                          "type": "string",
                        },
                        "type": "array",
                      },
                      "knowledge_layer": {
                        "enum": [
                          "personal",
                          "team",
                        ],
                        "type": "string",
                      },
                      "knowledge_type": {
                        "enum": [
                          "model",
                          "decision",
                          "guideline",
                          "pitfall",
                          "process",
                        ],
                        "type": "string",
                      },
                      "layer_reason": {
                        "type": "string",
                      },
                      "maturity": {
                        "enum": [
                          "draft",
                          "verified",
                          "proven",
                        ],
                        "type": "string",
                      },
                      "must_read_if": {
                        "type": "string",
                      },
                      "summary": {
                        "type": "string",
                      },
                      "tech_stack": {
