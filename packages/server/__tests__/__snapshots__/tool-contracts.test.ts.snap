exports[`tool contracts > fab-recall contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Recall Fabric knowledge (one-call)",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "client_hash": {
        "description": "Revision hash from a prior call; enables stale detection.",
        "type": "string",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records.",
        "type": "string",
      },
      "detected_entities": {
        "additionalProperties": {
          "items": {
            "type": "string",
          },
          "type": "array",
        },
        "description": "Optional path-keyed detected entities.",
        "type": "object",
      },
      "ids": {
        "description": "Optional explicit stable_ids to SCOPE the returned read paths. When omitted, \`paths\` carries one read path per surfaced candidate. The candidate DESCRIPTION index is always returned in full for discovery — \`ids\` only narrows which read paths are surfaced (e.g. when you already know which entries to Read). Stale ids are redirect-rewritten before matching.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "include_related": {
        "description": "When true, also surface the one-hop \`related\` graph neighbours (of the surfaced entries) that are present in the candidate set — their descriptions and read paths, NOT their bodies.",
        "type": "boolean",
      },
      "include_score_breakdown": {
        "description": "When true, populate \`entry.score_breakdown\` (numbers-only signal decomposition — bm25/vector/salience/recency/locality/proximity/credibility → final). Off by default for wire efficiency. Enable when debugging ranking or tuning scoring weights.",
        "type": "boolean",
      },
      "intent": {
        "description": "User-stated requirement or implementation intent; used to build a neutral requirement profile.",
        "type": "string",
      },
      "known_tech": {
        "description": "Known technologies involved.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "layer_filter": {
        "description": "Restrict recall to the named layer. Default: fabric-config.default_layer_filter.",
        "enum": [
          "team",
          "personal",
          "both",
        ],
        "type": "string",
      },
      "paths": {
        "description": "Candidate file paths to recall Fabric knowledge entries for. Same semantics as fab_plan_context.paths.",
        "items": {
          "type": "string",
        },
        "minItems": 1,
        "type": "array",
      },
      "session_id": {
        "description": "Current client session id (Claude Code: $session_id; Codex: corresponding identifier). Enables cross-session debt tracking. Falls back gracefully if omitted.",
        "type": "string",
      },
      "target_paths": {
        "description": "Path context for narrow-scope relevance filtering. Defaults to \`paths\`; empty = no filter.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
    },
    "required": [
      "paths",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "auto_healed": {
        "type": "boolean",
      },
      "dropped_ids": {
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "dropped_reasons": {
        "additionalProperties": false,
        "properties": {
          "payload_budget": {
            "minimum": 0,
            "type": "integer",
          },
          "retrieval_budget": {
            "minimum": 0,
            "type": "integer",
          },
        },
        "type": "object",
      },
      "entries": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "body_in_context": {
              "type": "boolean",
            },
            "description": {
              "additionalProperties": false,
              "properties": {
                "impact": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "knowledge_type": {
                  "enum": [
                    "models",
                    "decisions",
                    "guidelines",
                    "pitfalls",
                    "processes",
                  ],
                  "type": "string",
                },
                "must_read_if": {
                  "type": "string",
                },
                "summary": {
                  "type": "string",
                },
              },
              "required": [
                "summary",
              ],
              "type": "object",
            },
            "read_path": {
              "type": "string",
            },
            "score_breakdown": {
              "additionalProperties": false,
              "properties": {
                "bm25": {
                  "type": "number",
                },
                "bm25_rank": {
                  "type": "number",
                },
                "credibility": {
                  "type": "number",
                },
                "final": {
                  "type": "number",
                },
                "locality": {
                  "type": "number",
                },
                "proximity": {
                  "type": "number",
                },
                "recency": {
                  "type": "number",
                },
                "salience": {
                  "type": "number",
                },
                "vector": {
                  "type": "number",
                },
                "vector_rank": {
                  "type": "number",
                },
              },
              "required": [
                "final",
                "salience",
                "recency",
                "locality",
                "proximity",
              ],
              "type": "object",
            },
            "stable_id": {
              "type": "string",
            },
            "store_alias": {
              "type": "string",
            },
          },
          "required": [
            "stable_id",
            "description",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "next_steps": {
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "preflight_diagnostics": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "code": {
              "enum": [
                "missing_description",
                "empty_shell_suppressed",
              ],
              "type": "string",
            },
            "message": {
              "type": "string",
            },
            "path": {
              "type": "string",
            },
            "severity": {
              "const": "warn",
              "type": "string",
            },
            "stable_ids": {
              "items": {
                "type": "string",
              },
              "type": "array",
            },
          },
          "required": [
            "code",
            "severity",
            "message",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "previous_revision_hash": {
        "type": "string",
      },
      "redirects": {
        "additionalProperties": {
          "type": "string",
        },
        "type": "object",
      },
      "related_appended": {
        "additionalProperties": {
          "type": "string",
        },
        "type": "object",
      },
      "revision_hash": {
        "type": "string",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
            "message": {
              "type": "string",
            },
          },
          "required": [
            "code",
            "file",
            "action_hint",
          ],
          "type": "object",
        },
        "type": "array",
      },
