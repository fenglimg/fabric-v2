                "known_tech",
                "detected_entities",
              ],
              "type": "object",
            },
          },
          "required": [
            "path",
            "requirement_profile",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "intent": {
        "type": "string",
      },
      "omitted_candidate_count": {
        "minimum": 0,
        "type": "integer",
      },
      "preflight_diagnostics": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "code": {
              "enum": [
                "missing_description",
                "empty_shell_suppressed",
              ],
              "type": "string",
            },
            "message": {
              "type": "string",
            },
            "path": {
              "type": "string",
            },
            "severity": {
              "const": "warn",
