exports[`tool contracts > get-knowledge contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Get rule content",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "client_hash": {
        "description": "Revision hash from prior fab_get_rules response; enables stale detection",
        "type": "string",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records",
        "type": "string",
      },
      "path": {
        "description": "Target file path to query rules for",
        "type": "string",
      },
      "session_id": {
        "description": "Optional caller-provided session id for Event Ledger records",
        "type": "string",
      },
    },
    "required": [
      "path",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "revision_hash": {
        "type": "string",
      },
      "rules": {
        "additionalProperties": false,
        "properties": {
          "L0": {
            "type": "string",
          },
          "L1": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "content": {
                  "type": "string",
                },
                "path": {
                  "type": "string",
                },
              },
              "required": [
                "path",
                "content",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "L2": {
            "items": {
              "$ref": "#/properties/rules/properties/L1/items",
            },
            "type": "array",
          },
          "description_stubs": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "description": {
                  "type": "string",
                },
                "path": {
                  "type": "string",
                },
              },
              "required": [
                "path",
                "description",
              ],
              "type": "object",
            },
            "type": "array",
          },
          "human_locked_nearby": {
            "items": {
              "additionalProperties": false,
              "properties": {
                "excerpt": {
                  "type": "string",
                },
                "file": {
                  "type": "string",
                },
              },
              "required": [
                "file",
                "excerpt",
              ],
              "type": "object",
            },
            "type": "array",
          },
        },
        "required": [
          "L0",
          "L1",
          "L2",
          "human_locked_nearby",
        ],
        "type": "object",
      },
      "stale": {
        "type": "boolean",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
          },
          "required": [
            "code",
            "file",
            "action_hint",
          ],
          "type": "object",
        },
        "type": "array",
      },
    },
    "required": [
      "revision_hash",
      "stale",
      "rules",
    ],
    "type": "object",
  },
}
`;

exports[`tool contracts > knowledge-sections contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Filter rule sections",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "ai_selected_stable_ids": {
        "description": "AI-selected L1 stable_ids chosen from fab_plan_context ai_selectable_stable_ids",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "ai_selection_reasons": {
        "additionalProperties": {
          "minLength": 1,
          "type": "string",
        },
        "description": "Reason for each AI-selected L1 stable_id",
        "type": "object",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records",
        "type": "string",
      },
      "sections": {
        "description": "Structured rule sections to fetch",
        "items": {
          "enum": [
            "MISSION_STATEMENT",
            "MANDATORY_INJECTION",
            "BUSINESS_LOGIC_CHUNKS",
            "CONTEXT_INFO",
          ],
          "type": "string",
        },
        "minItems": 1,
        "type": "array",
      },
      "selection_token": {
        "description": "Selection token returned by fab_plan_context",
        "minLength": 1,
        "type": "string",
      },
      "session_id": {
        "description": "Optional caller-provided session id for Event Ledger records",
        "type": "string",
      },
    },
    "required": [
      "selection_token",
      "sections",
      "ai_selected_stable_ids",
      "ai_selection_reasons",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "diagnostics": {
        "items": {
          "anyOf": [
            {
              "additionalProperties": false,
              "properties": {
                "code": {
                  "const": "missing_section",
                  "type": "string",
                },
                "message": {
                  "type": "string",
                },
                "section": {
                  "enum": [
                    "MISSION_STATEMENT",
                    "MANDATORY_INJECTION",
                    "BUSINESS_LOGIC_CHUNKS",
                    "CONTEXT_INFO",
                  ],
                  "type": "string",
                },
                "severity": {
                  "const": "warn",
                  "type": "string",
                },
                "stable_id": {
                  "type": "string",
                },
              },
              "required": [
                "code",
                "severity",
                "stable_id",
                "section",
                "message",
              ],
              "type": "object",
            },
            {
              "additionalProperties": false,
              "properties": {
                "code": {
                  "const": "missing_knowledge_metadata",
                  "type": "string",
                },
                "message": {
                  "type": "string",
                },
                "severity": {
                  "const": "warn",
                  "type": "string",
                },
                "stable_id": {
                  "type": "string",
                },
              },
              "required": [
                "code",
                "severity",
                "stable_id",
                "message",
              ],
              "type": "object",
            },
          ],
        },
        "type": "array",
      },
      "precedence": {
        "items": [
          {
            "const": "L2",
            "type": "string",
          },
          {
            "const": "L1",
            "type": "string",
          },
          {
            "const": "L0",
            "type": "string",
          },
        ],
        "maxItems": 3,
        "minItems": 3,
        "type": "array",
      },
      "redirect_to": {
        "additionalProperties": false,
        "description": "Post-layer-flip redirect. Populated when stable_id changed after token mint (rc.3 fab_review/modify).",
        "properties": {
          "stable_id": {
            "type": "string",
          },
        },
        "required": [
          "stable_id",
        ],
        "type": "object",
      },
      "revision_hash": {
        "type": "string",
      },
      "rules": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "level": {
              "enum": [
                "L0",
                "L1",
                "L2",
              ],
              "type": "string",
            },
            "path": {
              "type": "string",
            },
            "sections": {
              "additionalProperties": {
                "type": "string",
              },
              "type": "object",
            },
            "stable_id": {
              "type": "string",
            },
          },
          "required": [
            "stable_id",
            "level",
            "path",
            "sections",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "selected_stable_ids": {
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
          },
          "required": [
