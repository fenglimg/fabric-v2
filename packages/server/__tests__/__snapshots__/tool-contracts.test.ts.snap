{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Browse and search pending knowledge entries",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "anyOf": [
      {
        "additionalProperties": false,
        "properties": {
          "action": {
            "const": "list",
            "type": "string",
          },
          "filters": {
            "additionalProperties": false,
            "properties": {
