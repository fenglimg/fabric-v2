          "deferred",
        ],
        "type": "object",
      },
    ],
  },
}
`;

exports[`tool contracts > knowledge-sections contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Fetch knowledge entry bodies",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "ai_selected_stable_ids": {
        "description": "Stable ids picked from fab_plan_context candidates[].stable_id; choose 1..N to fetch bodies for",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "ai_selection_reasons": {
        "additionalProperties": {
          "minLength": 1,
          "type": "string",
        },
        "default": {},
        "description": "Optional reason for each AI-selected L1 stable_id (audit telemetry). Omit to fetch bodies without annotating — server defaults to {} rather than rejecting the documented two-step call.",
        "type": "object",
      },
      "client_hash": {
        "description": "Optional caller-provided client hash propagated into knowledge_consumed events",
        "type": "string",
      },
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records",
        "type": "string",
      },
      "selection_token": {
        "description": "Selection token returned by fab_plan_context",
        "minLength": 1,
        "type": "string",
      },
      "session_id": {
        "description": "Optional caller-provided session id for Event Ledger records",
        "type": "string",
      },
    },
    "required": [
      "selection_token",
      "ai_selected_stable_ids",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "diagnostics": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "code": {
              "enum": [
                "missing_knowledge_metadata",
                "unresolved_selected_id",
              ],
              "type": "string",
            },
            "message": {
              "type": "string",
            },
            "severity": {
              "const": "warn",
              "type": "string",
            },
            "stable_id": {
              "type": "string",
            },
          },
          "required": [
            "code",
            "severity",
            "stable_id",
            "message",
          ],
          "type": "object",
        },
        "type": "array",
      },
