                "action_hint",
              ],
              "type": "object",
            },
            "type": "array",
          },
        },
        "required": [
          "action",
          "approved",
        ],
        "type": "object",
      },
      {
        "additionalProperties": false,
        "properties": {
          "action": {
            "const": "reject",
            "type": "string",
          },
