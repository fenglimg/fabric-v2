exports[`tool contracts > fab-archive-scan contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": true,
    "title": "Scan event ledger for archive candidates (deterministic)",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "correlation_id": {
        "description": "Optional caller-provided correlation id for Event Ledger records.",
        "type": "string",
      },
      "now_ms": {
        "description": "Override for the anti-loop cooldown clock (testing). Defaults to Date.now().",
        "minimum": 0,
        "type": "integer",
      },
      "range": {
        "anyOf": [
          {
            "items": {
              "type": "string",
            },
            "minItems": 1,
            "type": "array",
          },
          {
            "const": "all",
            "type": "string",
          },
        ],
        "description": "Phase 0 scope: explicit session_id[] to constrain the scan, or the 'all' sentinel. Omitted = scan everything since the last knowledge_proposed anchor.",
      },
      "session_id": {
        "description": "Current client session id; recorded for cross-session debt tracking.",
        "type": "string",
      },
    },
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "already_proposed_keys": {
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "anchor_ts": {
        "type": [
          "number",
          "null",
        ],
      },
      "covered_through_ts": {
        "type": [
          "number",
          "null",
        ],
      },
      "dropped": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "reason": {
              "enum": [
                "user_dismissed",
                "cooldown",
                "no_new_signal",
              ],
              "type": "string",
            },
            "session_id": {
              "type": "string",
            },
          },
          "required": [
            "session_id",
            "reason",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "session_ids": {
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
            "message": {
              "type": "string",
            },
          },
          "required": [
            "code",
            "file",
            "action_hint",
          ],
          "type": "object",
        },
        "type": "array",
      },
    },
    "required": [
      "anchor_ts",
      "session_ids",
      "dropped",
      "covered_through_ts",
      "already_proposed_keys",
    ],
    "type": "object",
  },
}
`;

exports[`tool contracts > fab-extract-knowledge contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": false,
    "title": "Extract pending knowledge entry",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "audience": {
        "description": "WHO this entry is for — an open scope coordinate (personal | team | project:x | org:y...). The sole author-facing audience field; the engine derives layer/visibility_store/store from it + the physical write store. Omit to default to project:<active> (bound repo) or team.",
        "pattern": "^[a-z0-9_-]+(:[a-z0-9_-]+)*$",
        "type": "string",
      },
      "evidence_paths": {
        "description": "Workspace-relative paths the agent CONSULTED (read but never modified) while building this knowledge. Documents context without affecting activation. Lifted from the legacy body ## Evidence markdown block into structured frontmatter so plan-context retrieval can read it as data.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "impact": {
        "description": "Consequences of ignoring this rule, used by the LLM to weight relevance vs cost. Each item ≤120 chars (e.g. 'O(n²) re-render on every frame', 'silent data loss on collision'). Optional — omit when impact is not observable.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "intent_clues": {
        "description": "Short LLM-readable triggers describing when this rule should fire and when it should not. Each item ≤80 chars, imperative phrasing (e.g. 'when editing Cocos UI batch code', 'NOT for non-batch contexts'). Optional — omit when the skill cannot infer cleanly.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "must_read_if": {
        "description": "One-line strong trigger; when this condition holds the entry is considered required reading. Single line ≤160 chars (e.g. 'touching anything under packages/cli/src/commands/hooks.ts'). Optional — omit when no single strong trigger fits.",
        "type": "string",
      },
      "onboard_slot": {
        "description": "Optional slot tag from the S5 onboarding set (tech-stack-decision / architecture-pattern / code-style-tone / build-system-idiom / domain-vocabulary); lets fabric-archive's first-run phase claim a project-tone slot. Skill propose-time only; never required.",
        "enum": [
          "tech-stack-decision",
          "architecture-pattern",
          "code-style-tone",
          "build-system-idiom",
          "domain-vocabulary",
        ],
        "type": "string",
      },
      "paths": {
        "description": "Relevance anchors (workspace-relative globs/paths). Non-empty → narrow (surface only on matching edits); empty/omitted → broad (always surface). The engine derives relevance_scope from this — there is no separate scope flag.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "proposed_reason": {
        "description": "Why this entry is being proposed. Drives \`## Why proposed\` rendering and enables future maturity-promotion scoring.",
        "enum": [
          "explicit-user-mark",
          "diagnostic-then-fix",
          "decision-confirmation",
          "wrong-turn-revert",
          "new-dependency-or-pattern",
          "dismissal-with-reason",
        ],
        "type": "string",
      },
      "recent_paths": {
        "description": "Workspace paths recently touched in the source session — used as scope hints",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "session_context": {
        "description": "3-5 line markdown blob — session goal + key turning point. Reviewed by future-self without transcript access.",
        "minLength": 20,
        "type": "string",
      },
      "slug": {
        "description": "URL-safe short identifier proposed by the Skill; server may sanitize",
        "type": "string",
      },
      "source_sessions": {
        "description": "Originating session ids (REQUIRED, non-empty array); correlates with Event Ledger records. Array form (T5+, rc.23 made it the sole accepted shape).",
        "items": {
          "minLength": 1,
          "type": "string",
        },
        "minItems": 1,
        "type": "array",
      },
      "tags": {
        "description": "Optional topic tags (2-4 kebab-case strings recommended). Drives cross-entry retrieval + topic clustering. Skill-inferred from session content; omit when not confidently inferable. Empty array allowed but discouraged (degrades narrow hint topic signal).",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "tech_stack": {
        "description": "DEPRECATED (v-next grill D2): new writes merge tech_stack values into tags. Field retained for backward-compatible parsing of existing entries. Was: tech stack / languages / frameworks the rule applies to.",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "type": {
        "description": "Knowledge type bucket (plural form, mirrors directory layout)",
        "enum": [
          "decisions",
          "pitfalls",
          "guidelines",
          "models",
          "processes",
        ],
        "type": "string",
      },
      "user_messages_summary": {
        "description": "Skill-side summary of the user's intent/messages, kept compact",
        "type": "string",
      },
    },
    "required": [
      "source_sessions",
      "recent_paths",
      "user_messages_summary",
      "type",
      "slug",
      "proposed_reason",
      "session_context",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "idempotency_key": {
        "description": "Stable key derived from inputs; identical inputs yield identical key",
        "type": "string",
      },
      "pending_path": {
        "description": "Workspace-relative path to the persisted pending entry",
        "type": "string",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
            "message": {
              "type": "string",
            },
          },
          "required": [
            "code",
            "file",
            "action_hint",
          ],
          "type": "object",
        },
        "type": "array",
      },
    },
    "required": [
      "pending_path",
      "idempotency_key",
    ],
    "type": "object",
  },
}
`;

