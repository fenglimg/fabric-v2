                    "personal",
                  ],
                  "type": "string",
                },
                "maturity": {
                  "enum": [
                    "draft",
                    "verified",
                    "proven",
                  ],
                  "type": "string",
                },
                "origin": {
                  "enum": [
                    "team",
                    "personal",
                  ],
                  "type": "string",
                },
                "pending_path": {
                  "type": "string",
                },
                "pending_path_absolute": {
                  "type": "string",
                },
                "status": {
                  "enum": [
                    "active",
                    "rejected",
                    "deferred",
                  ],
                  "type": "string",
                },
                "summary": {
                  "type": "string",
                },
                "tags": {
                  "items": {
                    "type": "string",
                  },
                  "type": "array",
                },
                "title": {
                  "type": "string",
                },
                "type": {
                  "enum": [
                    "decisions",
                    "pitfalls",
                    "guidelines",
                    "models",
                    "processes",
                  ],
                  "type": "string",
                },
              },
              "required": [
                "pending_path",
