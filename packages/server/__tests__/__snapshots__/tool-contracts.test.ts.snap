          "pending_path",
          "changes",
        ],
        "type": "object",
      },
      {
        "additionalProperties": false,
        "properties": {
          "action": {
            "const": "modify-content",
            "type": "string",
          },
          "changes": {
            "$ref": "#/anyOf/2/properties/changes",
          },
          "pending_path": {
            "minLength": 1,
            "type": "string",
          },
        },
        "required": [
          "action",
          "pending_path",
          "changes",
        ],
        "type": "object",
      },
      {
        "additionalProperties": false,
        "properties": {
          "action": {
            "const": "modify-layer",
            "type": "string",
          },
          "changes": {
            "additionalProperties": false,
            "properties": {
              "layer": {
                "enum": [
                  "team",
                  "personal",
                ],
                "type": "string",
              },
              "maturity": {
                "$ref": "#/anyOf/2/properties/changes/properties/maturity",
              },
              "related": {
                "$ref": "#/anyOf/2/properties/changes/properties/related",
              },
