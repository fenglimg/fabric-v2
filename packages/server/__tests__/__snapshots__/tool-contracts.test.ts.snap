            "type": "string",
          },
          "new_stable_id": {
            "type": "string",
          },
          "pending_path": {
            "type": "string",
          },
          "prior_stable_id": {
            "type": "string",
          },
          "warnings": {
            "items": {
              "$ref": "#/anyOf/0/properties/warnings/items",
            },
            "type": "array",
          },
        },
        "required": [
          "action",
          "pending_path",
        ],
        "type": "object",
      },
      {
        "additionalProperties": false,
        "properties": {
          "action": {
            "const": "defer",
            "type": "string",
          },
          "deferred": {
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "warnings": {
            "items": {
