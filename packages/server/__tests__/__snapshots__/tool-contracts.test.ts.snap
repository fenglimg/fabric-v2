            },
            "stable_ids": {
              "items": {
                "type": "string",
              },
              "type": "array",
            },
          },
          "required": [
            "code",
            "severity",
            "message",
          ],
          "type": "object",
        },
        "type": "array",
      },
      "previous_revision_hash": {
        "type": "string",
      },
      "redirects": {
        "additionalProperties": {
          "type": "string",
        },
        "type": "object",
      },
      "related_appended": {
        "additionalProperties": {
          "type": "string",
        },
        "type": "object",
      },
      "revision_hash": {
        "type": "string",
      },
      "selection_token": {
        "type": "string",
      },
      "stale": {
        "type": "boolean",
      },
      "warnings": {
        "items": {
          "additionalProperties": false,
          "properties": {
            "action_hint": {
              "type": "string",
            },
            "code": {
              "type": "string",
            },
            "file": {
              "type": "string",
            },
            "line": {
              "type": "number",
            },
            "message": {
              "type": "string",
            },
          },
          "required": [
            "code",
            "file",
            "action_hint",
          ],
          "type": "object",
        },
        "type": "array",
      },
    },
    "required": [
      "revision_hash",
      "stale",
      "selection_token",
      "entries",
      "candidates",
      "preflight_diagnostics",
    ],
    "type": "object",
  },
}
`;
