// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`tool contracts > fab-extract-knowledge contract matches snapshot 1`] = `
{
  "annotations": {
    "destructiveHint": false,
    "idempotentHint": true,
    "openWorldHint": false,
    "readOnlyHint": false,
    "title": "Extract pending knowledge entry",
  },
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "layer": {
        "description": "Storage layer for the pending entry. 'team' writes under the workspace; 'personal' writes under the user's home. Defaults to 'team'.",
        "enum": [
          "team",
          "personal",
        ],
        "type": "string",
      },
      "recent_paths": {
        "description": "Workspace paths recently touched in the source session — used as scope hints",
        "items": {
          "type": "string",
        },
        "type": "array",
      },
      "slug": {
        "description": "URL-safe short identifier proposed by the Skill; server may sanitize",
        "type": "string",
      },
      "source_session": {
        "description": "Originating session id; correlates with Event Ledger records",
        "type": "string",
      },
      "type": {
        "description": "Knowledge type bucket (plural form, mirrors directory layout)",
        "enum": [
          "decisions",
          "pitfalls",
          "guidelines",
          "models",
          "processes",
        ],
        "type": "string",
      },
      "user_messages_summary": {
        "description": "Skill-side summary of the user's intent/messages, kept compact",
        "type": "string",
      },
    },
    "required": [
      "source_session",
      "recent_paths",
      "user_messages_summary",
      "type",
      "slug",
    ],
    "type": "object",
  },
  "outputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "properties": {
      "idempotency_key": {
        "description": "Stable key derived from inputs; identical inputs yield identical key",
        "type": "string",
      },
      "pending_path": {
        "description": "Workspace-relative path to the persisted pending entry",
        "type": "string",
      },
    },
    "required": [
      "pending_path",
      "idempotency_key",
    ],
    "type": "object",
  },
}
`;

