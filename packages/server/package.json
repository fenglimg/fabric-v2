{
  "name": "@fenglimg/fabric-server",
  "version": "2.3.0-rc.1",
  "description": "Fabric MCP knowledge server — stdio transport for Claude Code / Codex CLI, manages .fabric/ knowledge base + agents.meta.json + event ledger.",
  "license": "MIT",
  "author": "wangzhichao <fenglimg90@gmail.com>",
  "homepage": "https://github.com/fenglimg/fabric-v2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fenglimg/fabric-v2.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/fenglimg/fabric-v2/issues"
  },
  "keywords": [
    "fabric",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "codex-cli",
    "ai-knowledge-management",
    "stdio"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
