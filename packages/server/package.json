    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fenglimg/fabric-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "minimatch": "^10.0.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
