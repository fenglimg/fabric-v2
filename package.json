{
  "name": "fabric-monorepo",
  "private": true,
  "version": "1.8.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:skills": "node --experimental-strip-types scripts/build-skills.ts",
    "prebuild": "pnpm build:skills",
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "knip --strict",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "^6.12.0",
    "lefthook": "^1.7.18",
    "vitest": "^3.2.4"
  }
}
