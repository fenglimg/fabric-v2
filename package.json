{
  "name": "fabric-monorepo",
  "private": true,
  "version": "2.0.0-rc.33",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "rc5:gate": "node scripts/rc5-coverage-gate.mjs",
    "rc6:gate": "node scripts/rc6-coverage-gate.mjs",
    "lint": "knip --strict",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "^6.12.0",
    "lefthook": "^1.7.18",
    "ts-prune": "^0.10.3",
    "vitest": "^3.2.4"
  }
}
