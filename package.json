{
  "name": "fabric-monorepo",
  "private": true,
  "version": "1.7.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:skills": "node --experimental-strip-types scripts/build-skills.ts",
    "prebuild": "pnpm build:skills",
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r --if-present test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^1.7.18",
    "vitest": "^3.2.4"
  }
}
