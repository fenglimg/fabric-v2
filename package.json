{
  "name": "fabric-monorepo",
  "private": true,
  "version": "2.3.0-rc.12",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "test:strategy": "node scripts/test-strategy-gate.mjs",
    "test:store-only-e2e": "node scripts/store-only-e2e.mjs",
    "test:upgrade-e2e": "node scripts/upgrade-e2e.mjs",
    "dogfood:first-value": "node scripts/dogfood-first-value.mjs",
    "lint": "knip --strict",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "prepare": "lefthook install",
    "dogfood:multi-store": "node scripts/dogfood-multi-store.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "^6.12.0",
    "lefthook": "^1.7.18",
    "vitest": "^3.2.4"
  }
}
