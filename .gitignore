node_modules/
**/node_modules/
dist/
**/dist/
coverage/
**/coverage/
*.js.map
.DS_Store
.fabric/.cache/
.fabric/cache/
.fabric/events.jsonl
.fabric/events.archive/
.fabric/events.jsonl.corrupted.*
.fabric/metrics.jsonl
.fabric/cite-rollup.jsonl
.fabric-personal-dogfood-tmp/
# MCP client configs contain absolute local paths — per-machine, not for repo
.mcp.json
.cursor/mcp.json

# maestro CLI session debris — empty spec stubs auto-created by `maestro spec
# load` (E1.5 of execute workflow), plus per-invocation analytics. No real
# content, regenerated on each session.
.workflow/specs/
.workflow/spec-analytics.jsonl
# rc.26: fabric wiki cache + per-package .fabric cache dirs created by local
# dogfood / build runs are not part of the source contract.
.workflow/wiki-index.json
packages/*/.fabric/
# Stray fabric runtime dir minted by a `fabric install` run with cwd=packages/
# (the pattern above only catches packages/<pkg>/.fabric, one level deeper).
packages/.fabric/
# KT-PIT-0034: a hook bug used to mint .fabric telemetry under the edited file's
# subdir (e.g. packages/shared/src/i18n/locales/.fabric/). Root cause fixed in
# 062cd0b; this catches any stray non-root .fabric runtime artifacts at ANY depth
# by their signature files. Tracked fixtures (cocos-stub/.fabric) hold none of
# these, and the root .fabric has its own .gitignore — both are untouched.
**/.fabric/events.jsonl
**/.fabric/metrics.jsonl
**/.fabric/cite-rollup.jsonl
**/.fabric/injections.jsonl
**/.fabric/.cache/
# Local-only caches & generated binaries regenerated by maestro/fabric runs —
# not part of the source contract (the 9MB maestro.db churns every session).
.workflow/kg/*.db
.workflow/embedding-index.bin
.workflow/search-cache.json
.workflow/search-cache.json.tmp
.workflow/explore/
# vector embedding store (zvec — RocksDB-style LOCK/WAL/manifest binary state)
# and the search-daemon PID/port sidecar. Per-machine transient runtime state
# minted by local dogfood runs; never in VCS. NOTE: .workflow/.scratchpad/ is
# intentionally NOT ignored — it holds tracked methodology/evidence docs the
# test-strategy gate requires (e.g. e2e-methodology-FINAL.md); never blanket-
# ignore it, and never `git add -A` transient prompts into it.
.workflow/embedding.zvec/
.workflow/search-daemon.json

# Local milestone/worktree checkouts. The tracked registry lives in
# .workflow/worktrees.json; do not vendor nested repositories into main.
.worktrees/
.claude/worktrees/

.antigravitycli
.ace-tool/

# ux-w2-1: Fabric dogfood mirror trees (5→1). Single source of truth is
# packages/cli/templates/{hooks,skills}; `fabric install` regenerates these
# per-client mirrors locally, so they need not be tracked (kills the 4-copy
# maintenance tax — ISS-20260608-022). Tests read templates + tmpdir fixtures,
# never these repo mirrors, so CI fresh-checkout is unaffected. Project-owned,
# non-mirror content stays tracked: .claude/settings*.json and the hand-kept
# .claude/skills/{release-rc,ui-ux-pro-max}.
.claude/hooks/
.claude/skills/fabric/
.claude/skills/fabric-*/
.claude/skills/lib/
.codex/
packages/cli/.claude/
packages/cli/.codex/

# embedding model cache (downloaded on demand; never in VCS)
local_cache/
**/local_cache/

# One-off i18n parity audit (en vs zh-CN key/leak diff). Reads built dist/, so
# it is a local dev tool — kept out of VCS by its own design (self-marked
# "not committed"); not a CI gate.
scripts/i18n-audit.mjs

# repo-hygiene-slim (2026-07-12): maestro CLI session runtime + issue-mine discoveries.
# Registry/state and issues/*.jsonl stay tracked; only per-run session dirs & discovery blobs.
.workflow/.maestro/
.workflow/issues/discoveries/
