# MCP client configs contain absolute local paths — per-machine, not for repo
.mcp.json
.cursor/mcp.json

# maestro CLI session debris — empty spec stubs auto-created by `maestro spec
# load` (E1.5 of execute workflow), plus per-invocation analytics. No real
# content, regenerated on each session.
.workflow/specs/
.workflow/spec-analytics.jsonl
# rc.26: fabric wiki cache + per-package .fabric cache dirs created by local
# dogfood / build runs are not part of the source contract.
.workflow/wiki-index.json
packages/*/.fabric/
# Stray fabric runtime dir minted by a `fabric install` run with cwd=packages/
# (the pattern above only catches packages/<pkg>/.fabric, one level deeper).
packages/.fabric/
# Local-only caches & generated binaries regenerated by maestro/fabric runs —
# not part of the source contract (the 9MB maestro.db churns every session).
.workflow/kg/*.db
.workflow/embedding-index.bin
.workflow/search-cache.json
.workflow/explore/

# Local milestone/worktree checkouts. The tracked registry lives in
# .workflow/worktrees.json; do not vendor nested repositories into main.
.worktrees/
.claude/worktrees/

.antigravitycli
.ace-tool/

# ux-w2-1: Fabric dogfood mirror trees (5→1). Single source of truth is
# packages/cli/templates/{hooks,skills}; `fabric install` regenerates these
# per-client mirrors locally, so they need not be tracked (kills the 4-copy
# maintenance tax — ISS-20260608-022). Tests read templates + tmpdir fixtures,
# never these repo mirrors, so CI fresh-checkout is unaffected. Project-owned,
# non-mirror content stays tracked: .claude/settings*.json and the hand-kept
# .claude/skills/{release-rc,ui-ux-pro-max}.
.claude/hooks/
.claude/skills/fabric/
.claude/skills/fabric-*/
.claude/skills/lib/
.codex/
packages/cli/.claude/
packages/cli/.codex/
