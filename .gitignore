**/node_modules/
dist/
**/dist/
coverage/
**/coverage/
*.js.map
.DS_Store
.fabric/.cache/
.fabric/cache/
.fabric/events.jsonl
.fabric/events.archive/
.fabric/events.jsonl.corrupted.*
.fabric/metrics.jsonl
