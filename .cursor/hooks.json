{
  "version": 1,
  "hooks": {
    "stop": [
      {
        "command": ".cursor/hooks/fabric-hint.cjs"
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/cite-policy-evict.cjs"
      },
      {
        "command": ".cursor/hooks/knowledge-hint-broad.cjs"
      }
    ],
    "preToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "command": ".cursor/hooks/knowledge-hint-narrow.cjs"
      }
    ]
  }
}
