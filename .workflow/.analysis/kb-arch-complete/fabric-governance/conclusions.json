{
  "system": "fabric-v2",
  "analysis_date": "2026-06-19",
  "governance_mechanisms": {
    "doctor_lint": {
      "name": "fabric doctor",
      "description": "诊断和修复 Fabric 工作区问题的综合 lint 系统",
      "total_checks": 48,
      "check_categories": [
        "bootstrap (anchor/snapshot/managed-block)",
        "event-ledger (existence/writability/partial-write/schema-compat)",
        "knowledge (age/integrity/scope/relevance)",
        "store (counter-drift/orphan/scope-lint)",
        "hooks (wired/runtime/content-drift)",
        "skills (ref-mirror/token-budget/description/yaml-valid)"
      ],
      "modes": {
        "lint": "只读诊断 (fabric doctor)",
        "fix": "自动修复派生状态 (fabric doctor --fix)",
        "fix-knowledge": "自动修复知识条目 (fabric doctor --fix-knowledge)"
      },
      "exit_codes": {
        "0": "all OK or warnings in non-strict mode",
        "1": "errors present or strict + warnings"
      }
    },
    "knowledge_decay_lints": {
      "orphan_demote": {
        "code": "knowledge_orphan_demote_required",
        "description": "知识条目长时间无活动, 按 maturity tier 降级",
        "thresholds": {
          "proven": "90 days inactivity",
          "verified": "30 days inactivity",
          "draft": "14 days inactivity"
        },
        "action": "demote one maturity tier (proven→verified→draft)",
        "source": "events.jsonl last knowledge event",
        "fixable": false,
        "severity": "warning"
      },
      "stale_archive": {
        "code": "knowledge_stale_archive_required",
        "description": "draft 条目静默超过阈值, 归档候选",
        "threshold": "draft (14d) + 90d additional = 104d total",
        "action": "move to .fabric/.archive/<type>/",
        "fixable": false,
        "severity": "warning"
      }
    },
    "store_integrity_lints": {
      "stable_id_collision": {
        "code": "knowledge_stable_id_collision",
        "description": "多个条目共享同一 stable_id",
        "action": "手动修复",
        "severity": "warning"
      },
      "layer_mismatch": {
        "code": "knowledge_layer_mismatch",
        "description": "文件路径 layer 与 frontmatter layer 不一致",
        "action": "手动修复 (可能需要 layer-flip)",
        "severity": "manual_error"
      },
      "store_counter_drift": {
        "code": "store_counter_drift",
        "description": "per-store counters.json 与实际 disk-max 不一致",
        "action": "floor to disk-max",
        "fixable": true,
        "severity": "fixable_error"
      },
      "store_orphan": {
        "code": "store_orphan",
        "description": "on-disk store 不在 registry 中",
        "action": "adopt (re-register)",
        "fixable": true,
        "severity": "warning"
      }
    },
    "relevance_lints": {
      "relevance_paths_dangling": {
        "description": "relevance_paths 锚点指向不存在的工作区文件",
        "severity": "warning"
      },
      "relevance_paths_drift": {
        "description": "narrow anchors 长时间无 git 活动",
        "severity": "info"
      },
      "narrow_no_paths": {
        "description": "narrow-scope entry 有空 relevance_paths",
        "severity": "warning"
      },
      "broad_index_drift": {
        "description": "broad entry count 接近 backstop 阈值",
        "severity": "warning"
      }
    },
    "lifecycle_status": {
      "pending_states": ["active", "rejected", "deferred"],
      "canonical_states": ["draft", "verified", "proven"],
      "transition_events": [
        "knowledge_proposed",
        "knowledge_promote_started",
        "knowledge_promoted",
        "knowledge_promote_failed",
        "knowledge_rejected",
        "knowledge_deferred",
        "knowledge_demoted",
        "knowledge_archived",
        "knowledge_layer_changed",
        "knowledge_id_redirect",
        "knowledge_scope_degraded"
      ]
    }
  },
  "archive_review_sync_flow": {
    "archive_skill": {
      "name": "fabric-archive",
      "description": "归档对话洞察到 active write store 的 pending knowledge",
      "trigger_signals": [
        "User-driven normative (以后/always/never/记一下)",
        "Wrong-turn-and-revert (AI 反思路径)",
        "Stop-hook JSON decision block",
        "显式用户请求"
      ],
      "phases": [
        "Phase 0: Range Resolution",
        "Phase 0.5: Config Load",
        "Phase 0.6: Store routing",
        "Phase 1: Collect Cross-Session Digests (fab_archive_scan)",
        "Phase 2: Collect Candidates",
        "Phase 2.5: Viability Gate",
        "Phase 3: Classify, Layer, Slug, Review",
        "Phase 3.5: Scope Decision + relevance_paths",
        "Phase 3.6: Related-edge Extraction",
        "Phase 3.7: Semantic scope",
        "Phase 4: Persist via MCP (fab_extract_knowledge)",
        "Phase 4.5: Persist Archive Attempt"
      ],
      "max_candidates_per_batch": 8,
      "output": "pending entries in write store knowledge/pending/<type>/"
    },
    "review_skill": {
      "name": "fabric-review",
      "description": "审 store-backed pending+canonical knowledge",
      "modes": {
        "pending": "triage write-side backlog (approve/reject/modify/defer)",
        "maintain": "sustain existing canonical KB (search/health/revisit)"
      },
      "actions": [
        "list - 列 pending 条目",
        "approve - 提升到 canonical (分配 stable_id)",
        "reject - 标记 status=rejected, 移到 rejected/",
        "modify - 编辑 frontmatter (内容或 layer-flip)",
        "modify-content - 仅编辑 scalars",
        "modify-layer - layer-flip (分配新 stable_id)",
        "search - 搜索 pending + canonical",
        "defer - 标记 status=deferred + deferred_until"
      ],
      "semantic_check": {
        "description": "LLM-assisted duplicate/contradiction detection",
        "overlap_bands": ["high", "medium", "low"],
        "flags": [
          "Possible duplicate of <stable_id>",
          "Contradicts <stable_id>",
          "Subsumed by <stable_id>"
        ]
      },
      "summary_self_sufficiency_gate": {
        "applies_to": ["guideline", "model"],
        "reason": "这些类型在 SessionStart ALWAYS-ACTIVE sink 中无 body 注入",
        "judge": "zero-context cold-eval (maestro delegate)"
      }
    },
    "sync_mechanism": {
      "description": "store repo commit 同步",
      "responsibility": "fabric sync skill",
      "scope": "store repo 的 pending-removal + canonical-add"
    }
  },
  "event_ledger_audit": {
    "location": ".fabric/events.jsonl",
    "schema_version": 1,
    "rotation_policy": {
      "window": "30 days",
      "archive_path": ".fabric/events-archive/"
    },
    "metrics_sidecar": {
      "file": "metrics.jsonl",
      "flush_trigger": "fabric doctor --fix"
    },
    "cite_coverage": {
      "command": "fabric doctor --cite-coverage",
      "metrics": [
        "edits_touched",
        "qualifying_cites",
        "recalled_unverified",
        "expected_but_missed",
        "cite_compliance_rate",
        "recall_coverage_rate"
      ],
      "contract_check": {
        "decisions_cited",
        "pitfalls_cited",
        "contract_with",
        "contract_missing",
        "hard_violated"
      }
    },
    "conflict_lint": {
      "command": "fabric doctor --lint-conflicts",
      "algorithm": "bm25 candidate pairs + optional LLM judge",
      "verdicts": ["conflict", "similar", "review"]
    }
  },
  "governance_flow": {
    "entry_points": [
      "fabric doctor (诊断)",
      "fabric doctor --fix (自动修复)",
      "fabric doctor --fix-knowledge (知识修复)",
      "fabric doctor --cite-coverage (引用覆盖率)",
      "fabric doctor --lint-conflicts (冲突检测)",
      "fabric-archive (归档)",
      "fabric-review (审核)"
    ],
    "lifecycle_states": {
      "pending": "active → rejected/deferred → promoted → canonical",
      "canonical": "draft → verified → proven → archived"
    },
    "audit_trail": "events.jsonl + cite-rollup.jsonl + metrics.jsonl"
  },
  "id_redirect_mechanism": {
    "description": "layer-flip 后的 id 映射",
    "event": "knowledge_id_redirect",
    "fields": ["previous_stable_id", "new_stable_id", "reason"],
    "consumers": ["fab_plan_context.redirects", "fab_get_knowledge_sections.redirect_to"]
  },
  "comparison_with_maestro": {
    "key_differences": [
      "fabric-v2: 自动化 lint 系统 (48 checks) + 可选自动修复",
      "maestro-flow: 显式用户决策驱动 (keep/deprecate/delete)",
      "fabric-v2: 分层 maturity ladder (draft/verified/proven)",
      "maestro-flow: 单一 P0/P1/P2 分级",
      "fabric-v2: events.jsonl 审计追踪 + id-redirect 机制",
      "maestro-flow: 单一 backup tarball",
      "fabric-v2: store-backed 多仓库模型",
      "maestro-flow: 单一 workspace 存储模型",
      "fabric-v2: 专用 skills (archive/review/sync)",
      "maestro-flow: 单一 audit skill"
    ]
  }
}
